<!-- views/index.ejs - Modern Redesign with Full Tailwind Styling -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Product Recommendations</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom scrollbar for the dark Engine Activity panel */
        .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #1f2937; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #6b7280; }
    </style>
</head>
<body class="bg-gray-100 font-sans text-gray-800 antialiased">
    <header id="navbar-placeholder" class="bg-white shadow-sm sticky top-0 z-50">
    </header>

    <!-- Main Content Container -->
    <div class="container max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-center mb-2 text-gray-900">Get Personalized Recommendations</h1>
        <!-- Subtitle will be added via JavaScript -->
        <p id="subtitle" class="text-center text-gray-600 text-lg mb-8"></p> <!-- Increased bottom margin -->

        <!-- Quick Try Buttons -->
        <div class="max-w-3xl mx-auto mb-6 flex flex-col sm:flex-row justify-center items-center gap-3">
            <span class="text-sm text-gray-500 font-medium">Quick Try:</span>
            <button type="button" class="quick-try-btn inline-flex items-center px-4 py-1.5 border border-gray-300 rounded-full shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 hover:border-indigo-300 hover:text-indigo-600 transition" data-id="C1001">
                🏃‍♂️ The Athlete
            </button>
            <button type="button" class="quick-try-btn inline-flex items-center px-4 py-1.5 border border-gray-300 rounded-full shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 hover:border-indigo-300 hover:text-indigo-600 transition" data-id="C1003">
                💻 Tech Geek
            </button>
            <button type="button" class="quick-try-btn inline-flex items-center px-4 py-1.5 border border-gray-300 rounded-full shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 hover:border-indigo-300 hover:text-indigo-600 transition" data-id="C1004">
                🎁 Holiday Shopper
            </button>
        </div>

        <!-- Alert for errors - Tailwind Styled -->
        <% if (locals.flash_error) { %>
            <div class="max-w-3xl mx-auto mb-8 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative flex items-center gap-x-2 shadow" role="alert">
                 <span class="block sm:inline"><i class="fas fa-exclamation-circle text-red-500"></i></span>
                 <span class="block sm:inline"><%= flash_error %></span>
            </div>
        <% } %>

        <!-- Main Form Card - Tailwind Styled -->
        <form method="post" id="recommendation-form" class="max-w-3xl mx-auto bg-white p-6 md:p-8 rounded-lg shadow-lg mb-12 border border-gray-200">
             <!-- Removed data-loading attribute - JS will handle state directly -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8"> <!-- Increased gap and bottom margin -->
                <div class="form-group">
                    <label for="customer_id" class="block text-sm font-medium text-gray-700 mb-1">Customer ID:</label>
                    <input type="text" id="customer_id" name="customer_id" value="<%= locals.customer_id || '' %>"
                           class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out" required placeholder="e.g., C1000">
                </div>

                <div class="form-group">
                    <label for="llm_service" class="block text-sm font-medium text-gray-700 mb-1">LLM Service:</label>
                    <select id="llm_service" name="llm_service" class="w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out">
                        <% Object.keys(model_options).forEach(service => { %>
                            <option value="<%= service %>" <% if (service === selected_service) { %>selected<% } %>>
                                <%= service.charAt(0).toUpperCase() + service.slice(1) %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="generation_model" class="block text-sm font-medium text-gray-700 mb-1">Generation Model:</label>
                    <select id="generation_model" name="generation_model" required class="w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out">
                        <!-- Options populated by JS -->
                        <option value="">-- Select Model --</option>
                    </select>
                </div>
            </div>

            <div class="form-footer text-center">
                <button type="submit" id="submit-button" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out disabled:opacity-50 disabled:cursor-not-allowed">
                    <!-- Icon and text will be managed by JS for loading state -->
                    <span id="button-icon"><i class="fas fa-magic mr-2"></i></span>
                    <span id="button-text">Get Recommendations</span>
                </button>
            </div>
        </form>

        <!-- Results Wrapper (Stacked Layout) -->
        <div id="results-wrapper" class="w-full mt-8">
            
            <!-- Top Section: Customer Profile -->
            <% if (profile_summary) { %>
                <div class="profile-section max-w-4xl mx-auto mb-12" id="profile-container">
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-200">
                        <div class="px-4 py-4 sm:px-6 border-b border-gray-200 bg-gray-50 flex items-center">
                            <i class="fas fa-user-circle text-gray-500 mr-2"></i>
                            <h2 class="text-lg leading-6 font-semibold text-gray-900">Customer Profile Summary</h2>
                        </div>
                        <div class="px-4 py-5 sm:p-6">
                            <pre class="profile-summary text-sm text-gray-700 overflow-x-auto whitespace-pre-wrap break-words bg-gray-50 p-4 rounded-md border border-gray-200 font-sans"><%= profile_summary %></pre>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <!-- Empty Placeholder -->
                <div class="hidden w-full" id="profile-placeholder"></div>
            <% } %>
            
            <!-- Skeleton for Profile (Hidden by default) -->
            <div id="profile-skeleton" class="hidden profile-section max-w-4xl mx-auto mb-12">
                <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-200 animate-pulse">
                    <div class="px-4 py-4 sm:px-6 border-b border-gray-100 bg-gray-50 flex items-center">
                        <div class="w-6 h-6 bg-gray-300 rounded-full mr-2"></div>
                        <div class="h-4 bg-gray-300 rounded w-1/4"></div>
                    </div>
                    <div class="p-4 sm:p-6 space-y-4">
                        <div class="h-3 bg-gray-200 rounded w-full"></div>
                        <div class="h-3 bg-gray-200 rounded w-5/6"></div>
                        <div class="h-3 bg-gray-200 rounded w-4/6"></div>
                        <div class="h-3 bg-gray-200 rounded w-full"></div>
                    </div>
                </div>
            </div>

            <!-- Bottom Section: Recommendations -->
            <!-- Skeleton Loader Container (Hidden by default) -->
            <div id="skeleton-loader" class="hidden recommendations-section">
                <h2 class="text-2xl sm:text-3xl font-semibold text-gray-800 mb-8 text-center pb-3 border-b border-gray-200"><span class="animate-pulse text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">✨ AI is Generating Insights...</span></h2>
                <ul class="recommendations-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                    <!-- Three skeleton cards -->
                    <% for(let i=0; i<3; i++) { %>
                    <li class="flex">
                        <div class="w-full bg-white shadow-lg rounded-lg overflow-hidden flex flex-col h-full border border-gray-200 animate-pulse">
                            <div class="w-full h-48 bg-gray-200"></div>
                            <div class="p-4 flex-grow flex flex-col">
                                <div class="h-3 bg-gray-200 rounded w-1/4 mb-3"></div>
                                <div class="h-5 bg-gray-300 rounded w-3/4 mb-3"></div>
                                <div class="h-4 bg-gray-200 rounded w-1/2 mb-4"></div>
                                <div class="mt-auto pt-3">
                                    <div class="h-24 bg-indigo-50/50 rounded-md border border-indigo-100"></div>
                                </div>
                            </div>
                        </div>
                    </li>
                    <% } %>
                </ul>
            </div>

            <!-- Recommendations Section -->
            <% if (Array.isArray(recommendations)) { %>
                <div class="recommendations-section mb-12" id="recommendations-container">
                    <h2 class="text-2xl sm:text-3xl font-semibold text-gray-800 mb-8 text-center pb-2 border-b border-gray-200">Recommendations</h2>
                    <% if (recommendations.length > 0) { %>
                        <!-- Tailwind grid for cards: 3 columns full width -->
                        <ul class="recommendations-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                            <% recommendations.forEach(rec => { %>
                            <!-- Tailwind Card -->
                            <li class="flex">
                                <% if (rec.error) { %>
                                    <div class="w-full bg-red-50 border border-red-200 rounded-lg shadow-lg overflow-hidden p-4 flex flex-col justify-center items-center text-center">
                                        <i class="fas fa-exclamation-triangle text-red-500 text-3xl mb-3"></i>
                                        <h3 class="text-lg font-semibold text-red-800 mb-1">Error Processing</h3>
                                        <p class="text-sm text-red-700 mb-2"><%= rec.error %></p>
                                        <% if (rec.id) { %><p class="text-xs text-red-600">Attempted ID: <%= rec.id %></p><% } %>
                                    </div>
                                <% } else { %>
                                    <div class="w-full bg-white shadow-lg rounded-lg overflow-hidden flex flex-col h-full transition-shadow duration-300 hover:shadow-xl border border-gray-200">
                                        <% const imageText = (rec.subcategory || 'Product').replace(/ /g, '+'); %>
                                        <% const imageUrl = 'https://placehold.co/300x200/EAEAEA/888?text=' + imageText; %>
                                        <div class="w-full h-48 bg-gray-200 flex-shrink-0">
                                            <img src="<%= imageUrl %>" alt="<%= rec.category || 'Product' %>" loading="lazy" class="w-full h-full object-cover">
                                        </div>
                                        <div class="p-4 flex-grow flex flex-col">
                                            <p class="uppercase tracking-wide text-xs font-bold text-indigo-600 mb-1"><%= rec.category || 'N/A' %></p>
                                            <h3 class="text-lg font-semibold text-gray-900 mb-1 leading-tight"><%= rec.id || 'N/A' %></h3>
                                            <p class="text-sm text-gray-600 mb-2">
                                                <%= rec.subcategory || 'N/A' %>
                                                <% if (rec.brand) { %> <span class="mx-1">|</span> <span class="font-medium text-gray-700"><%= rec.brand %></span> <% } %>
                                            </p>
                                            <p class="text-xl font-bold text-gray-800 mt-1 mb-3">
                                                $<%= typeof rec.price === 'number' ? rec.price.toFixed(2) : 'N/A' %>
                                            </p>
                                            <div class="flex-grow"></div>
                                            <% if (rec.why) { %>
                                                <div class="mt-3 pt-3 border-t border-gray-100">
                                                    <div class="text-sm text-gray-800 bg-gradient-to-br from-indigo-50 to-purple-50 p-3 rounded-md border border-indigo-100 relative shadow-inner">
                                                       <div class="absolute -top-3 -left-2 text-xl drop-shadow-sm">✨</div>
                                                       <span class="font-bold text-indigo-800 ml-3 inline-block mb-1">AI Insight:</span> 
                                                       <p class="leading-relaxed text-xs text-gray-700 italic">"<%= rec.why %>"</p>
                                                    </div>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div class="flex items-center p-3 border-t border-gray-200 bg-gray-50 text-sm text-gray-600 flex-shrink-0">
                                            <div class="flex items-center" title="Rating">
                                                 <i class="fas fa-star text-yellow-500 mr-1"></i>
                                                 <span class="font-medium text-gray-800 mr-1"><%= typeof rec.rating === 'number' ? rec.rating.toFixed(1) : 'N/A' %></span> / 5
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </li>
                        <% }); %>
                    </ul>
                <% } else { %>
                    <div class="empty-state text-center py-16 px-6 bg-white rounded-lg shadow-md max-w-lg mx-auto border border-gray-200">
                        <div class="empty-state-icon text-gray-400 mb-4">
                            <i class="fas fa-box-open text-6xl"></i>
                        </div>
                        <h3 class="empty-state-title text-xl font-semibold text-gray-700 mb-2">No Recommendations Found</h3>
                        <p class="empty-state-description text-gray-500">
                            We couldn't generate specific recommendations for this customer profile.
                            Try a different customer ID or adjust the model parameters.
                        </p>
                    </div>
                <% } %>
            </div> <!-- End Right Column (Recommendations) -->
        <% } %>
        </div> <!-- End Results Wrapper -->

        <!-- Debug Panel / Under the Hood -->
        <% if (locals.debug_info) { %>
            <div id="debug-section" class="w-full mb-12">
                <div class="max-w-5xl mx-auto">
                    <div class="flex justify-center pt-8 border-t border-gray-200">
                        <button type="button" id="debug-toggle-btn" class="flex items-center justify-center px-6 py-3 border border-gray-300 shadow-sm text-sm font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50 hover:text-indigo-600 transition">
                            <i class="fas fa-code mr-2 text-indigo-500"></i> View Engine Activity
                        </button>
                    </div>
                    <div id="debug-panel" class="hidden mt-6 bg-gray-900 rounded-lg shadow-xl overflow-hidden border border-gray-700 text-sm font-mono transition-all">
                    <div class="bg-gray-800 px-4 py-3 border-b border-gray-700 text-gray-300 flex justify-between items-center shadow-inner">
                        <span class="font-bold text-indigo-400 uppercase tracking-widest text-xs"><i class="fas fa-terminal mr-2"></i>Under The Hood</span>
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                    </div>
                    <div class="p-5 flex flex-col md:flex-row gap-6">
                        <div class="md:w-1/3">
                            <h4 class="text-gray-400 uppercase tracking-widest text-xs mb-3">Execution Pipeline</h4>
                            <ul class="space-y-3 text-indigo-200 text-xs">
                                <% debug_info.steps.forEach(step => { %>
                                    <li class="flex items-start">
                                        <span><%= step %></span>
                                    </li>
                                <% }) %>
                            </ul>
                        </div>
                        <div class="md:w-2/3">
                            <div class="flex items-center gap-4 mb-3 border-b border-gray-700 pb-2">
                                <button type="button" class="tab-btn text-xs uppercase tracking-widest font-bold text-indigo-400 focus:outline-none" onclick="document.getElementById('llm-prompt-box').classList.remove('hidden'); document.getElementById('llm-output-box').classList.add('hidden'); this.classList.add('text-indigo-400'); this.classList.remove('text-gray-500'); document.getElementById('tab-out').classList.remove('text-indigo-400'); document.getElementById('tab-out').classList.add('text-gray-500');" id="tab-in">LLM Prompt</button>
                                <button type="button" class="tab-btn text-xs uppercase tracking-widest font-bold text-gray-500 hover:text-gray-300 focus:outline-none" onclick="document.getElementById('llm-output-box').classList.remove('hidden'); document.getElementById('llm-prompt-box').classList.add('hidden'); this.classList.add('text-indigo-400'); this.classList.remove('text-gray-500'); document.getElementById('tab-in').classList.remove('text-indigo-400'); document.getElementById('tab-in').classList.add('text-gray-500');" id="tab-out">LLM Output</button>
                            </div>
                            <div id="llm-prompt-box" class="bg-black/60 p-4 rounded shadow-inner overflow-x-auto text-green-400 text-xs leading-relaxed max-h-64 overflow-y-auto custom-scrollbar">
                                <pre><%= debug_info.prompt %></pre>
                            </div>
                            <div id="llm-output-box" class="hidden bg-black/60 p-4 rounded shadow-inner overflow-x-auto text-yellow-400 text-xs leading-relaxed max-h-64 overflow-y-auto custom-scrollbar">
                                <pre><%= debug_info.llm_output || 'No output available' %></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

    </div> <!-- End Container -->

    <!-- About Project Modal (Hidden by default) -->
    <div id="about-modal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            
            <div class="fixed inset-0 bg-gray-900 bg-opacity-75 transition-opacity close-modal-btn cursor-pointer" aria-hidden="true" title="Close modal"></div>

            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white rounded-xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-gray-200">
                <div class="bg-indigo-900 border-b border-indigo-800 text-white px-6 py-5 flex items-center justify-between">
                    <h2 class="text-xl font-bold flex items-center" id="modal-title">
                        <i class="fas fa-briefcase text-indigo-400 mr-3 text-2xl"></i> Project Details
                    </h2>
                    <button type="button" class="close-modal-btn text-indigo-200 hover:text-white transition focus:outline-none">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <div class="px-6 py-6 border-b border-gray-100">
                    <p class="text-gray-600 text-sm leading-relaxed mb-3">
                        <strong class="text-gray-900">Goal:</strong> A hybrid recommendation engine combining deterministic SQLite filtering with LLM reasoning.
                    </p>
                    <p class="text-gray-600 text-sm leading-relaxed mb-5">
                        <strong class="text-gray-900">Dataset:</strong> Includes mock e-commerce datasets containing customer profiles (<code class="bg-gray-100 px-1 rounded text-xs">customer_data_collection.csv</code>) and product catalogs (<code class="bg-gray-100 px-1 rounded text-xs">product_recommendation_data.csv</code>) tailored for recommendation pipelines.
                    </p>
                    <div class="flex flex-wrap gap-2.5 text-xs font-semibold">
                        <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full border border-gray-200 inline-flex items-center"><i class="fab fa-node-js mr-1.5"></i>Node.js</span>
                        <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full border border-gray-200 inline-flex items-center"><i class="fas fa-server mr-1.5"></i>Express</span>
                        <span class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-full border border-gray-200 inline-flex items-center"><i class="fas fa-database mr-1.5"></i>SQLite</span>
                        <span class="bg-indigo-50 text-indigo-700 px-3 py-1.5 rounded-full border border-indigo-100 inline-flex items-center"><i class="fas fa-magic mr-1.5"></i>Gemini 3.1</span>
                        <span class="bg-indigo-50 text-indigo-700 px-3 py-1.5 rounded-full border border-indigo-100 inline-flex items-center"><i class="fas fa-brain mr-1.5"></i>Ollama</span>
                        <span class="bg-sky-50 text-sky-700 px-3 py-1.5 rounded-full border border-sky-100 inline-flex items-center"><i class="fab fa-css3-alt mr-1.5"></i>Tailwind</span>
                    </div>
                </div>
                <div class="px-6 py-4 bg-gray-50 flex justify-end">
                    <a href="https://github.com/saidhury/shoppingbuddy" target="_blank" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition">
                        <i class="fab fa-github mr-2"></i> View Source
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Make model options available to client-side JS -->
    <script>
        const modelOptionsData = <%- JSON.stringify(model_options || {}) %>;
        const previouslySelectedService = <%- JSON.stringify(selected_service || '') %>;
        const previouslySelectedModel = <%- JSON.stringify(selected_model || '') %>;
    </script>
    <!-- Ensure main.js is updated to handle the loading state via JS -->
    <script src="/js/main.js"></script>
</body>
</html>